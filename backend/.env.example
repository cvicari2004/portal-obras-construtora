# Database Configuration
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=portal_user
DATABASE_PASSWORD=secure_password_123
DATABASE_NAME=portal_obras_construtora
DATABASE_URL=postgresql://portal_user:secure_password_123@localhost:5432/portal_obras_construtora

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRATION=86400

# Server Configuration
PORT=3001
NODE_ENV=development

# File Upload
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=52428800
ALLOWED_MIME_TYPES=image/jpeg,image/png,image/gif,application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet

# LGPD Configuration
LGPD_ENABLED=true
LGPD_DISCLAIMER_VERSION=1.0

# Security
BCRYPT_ROUNDS=10
SESSION_TIMEOUT=3600000
MAX_LOGIN_ATTEMPTS=5
LOCK_TIME=900000
